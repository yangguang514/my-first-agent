{
  "version": 2,
  "builds": [
    {
      "src": "animalServer/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "animalClient/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "animalServer/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "animalClient/index.html"
    }
  ]
}
