ANIMAL_AGENT_API_KEY=your_model_api_key_here
ANIMAL_AGENT_BASE_URL=https://api.deepseek.com/v1
ANIMAL_AGENT_MODEL=deepseek-chat
ANIMAL_AGENT_TEMPERATURE=0.4

# Optional web search. Choose one: tavily, serper, brave, off
SEARCH_PROVIDER=tavily
SEARCH_API_KEY=your_search_api_key_here
SEARCH_MAX_RESULTS=5
SEARCH_TIMEOUT_MS=10000

# Local development:
STORAGE_PROVIDER=json

# Vercel deployment:
# STORAGE_PROVIDER=postgres
# Add Vercel Postgres / Neon env vars, for example POSTGRES_URL.

PORT=3010
