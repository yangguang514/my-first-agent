ANIMAL_AGENT_API_KEY=your_model_api_key_here
ANIMAL_AGENT_BASE_URL=https://api.deepseek.com/v1
ANIMAL_AGENT_MODEL=deepseek-chat
ANIMAL_AGENT_TEMPERATURE=0.4

# Optional web search. Choose one: tavily, serper, brave, off
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=your_tavily_api_key_here
SEARCH_MAX_RESULTS=5
SEARCH_TIMEOUT_MS=10000
SEARCH_SNIPPET_MAX_LENGTH=1600
SEARCH_STRICT_ERRORS=false

# LLM search planner. It decides whether to search before each answer.
# Defaults to ANIMAL_AGENT_MODEL when SEARCH_PLANNER_MODEL is empty.
SEARCH_PLANNER_DISABLED=false
SEARCH_PLANNER_MODEL=
SEARCH_PLANNER_TIMEOUT_MS=8000

# Tavily enhanced retrieval
TAVILY_SEARCH_DEPTH=advanced
TAVILY_CHUNKS_PER_SOURCE=3
TAVILY_INCLUDE_ANSWER=false
# false, true, markdown, or text
TAVILY_INCLUDE_RAW_CONTENT=false
TAVILY_AUTO_PARAMETERS=false
TAVILY_TOPIC=general
# TAVILY_USE_TRUSTED_DOMAINS=true
# TAVILY_INCLUDE_DOMAINS=iucnredlist.org,animaldiversity.org,itis.gov,gbif.org,eol.org
# TAVILY_EXCLUDE_DOMAINS=
# TAVILY_TIME_RANGE=
# TAVILY_COUNTRY=

# Local development:
STORAGE_PROVIDER=json

# Vercel deployment:
# STORAGE_PROVIDER=postgres
# Add Vercel Postgres / Neon env vars, for example POSTGRES_URL.

PORT=3010
